{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/index.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/*.{test,spec}.{ts,tsx}",
    "**/*.d.ts"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
